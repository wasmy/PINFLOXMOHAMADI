# Pinterest Login Credentials (required if session state doesn't exist)
PINTEREST_EMAIL=your_pinterest_email@example.com
PINTEREST_PASSWORD=your_pinterest_password

# Groq API (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Image generation fallback (optional — only if Pollinations.ai is down)
# Free at api.together.xyz
TOGETHER_API_KEY=

# Hugging Face Inference API (free at huggingface.co)
# Free tier: 2-3 images/minute on stabilityai/stable-diffusion-xl-base-1.0
HF_API_KEY=